def get_weather(location: str) -> str:
    return f"Weather in {location}: Clear, 75°F"

def analyze_risk(situation: str) -> str:
    situation = situation.lower()

    if "enemy" in situation:
        return "High risk detected"
    elif "low supplies" in situation or "cold" in situation:
        return "Moderate risk"
    else:
        return "Low risk"
